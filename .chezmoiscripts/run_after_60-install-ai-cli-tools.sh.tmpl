{{- if and (or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux")) (default false (get . "enableAiCliTools")) -}}
#!/bin/sh
set -eu

setup_mise() {
  if command -v mise >/dev/null 2>&1; then
    return
  fi

{{ if eq .chezmoi.os "darwin" }}
  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  fi

  if command -v mise >/dev/null 2>&1; then
    return
  fi

  if [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
{{ end }}

  if ! command -v mise >/dev/null 2>&1; then
    echo "mise is required to install optional AI CLI tools." >&2
    exit 1
  fi
}

setup_mise
mise install --yes -C "$HOME" node
mise exec --yes -C "$HOME" -- npm install -g \
  @anthropic-ai/claude-code \
  @google/gemini-cli \
  @openai/codex
{{- end }}
