{{- if eq .chezmoi.os "darwin" -}}
#!/bin/sh
set -eu

setup_mise() {
  if command -v mise >/dev/null 2>&1; then
    return
  fi

  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  fi

  if command -v mise >/dev/null 2>&1; then
    return
  fi

  if [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi

  if ! command -v mise >/dev/null 2>&1; then
    echo "mise is required. Run the Homebrew Brewfile bundle first." >&2
    exit 1
  fi
}

remove_legacy_claude_install() {
  legacy_claude_bin="$HOME/.local/bin/claude"
  legacy_claude_dir="$HOME/.local/share/claude"

  if [ -L "$legacy_claude_bin" ]; then
    legacy_claude_target="$(readlink "$legacy_claude_bin")"

    case "$legacy_claude_target" in
      "$legacy_claude_dir"/*)
        rm -f "$legacy_claude_bin"
        ;;
    esac
  fi

  if [ -d "$legacy_claude_dir" ]; then
    rm -rf "$legacy_claude_dir"
  fi
}

remove_legacy_npm_ai_tools() {
  if command -v npm >/dev/null 2>&1; then
    npm uninstall -g @anthropic-ai/claude-code @openai/codex >/dev/null 2>&1 || true
  fi

  mise exec --yes -C "$HOME" -- npm uninstall -g @anthropic-ai/claude-code @openai/codex >/dev/null 2>&1 || true
}

setup_mise
remove_legacy_claude_install
remove_legacy_npm_ai_tools
{{- end }}
