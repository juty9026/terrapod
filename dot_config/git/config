[merge]
	ff = false
	conflictStyle = zdiff3
[pull]
	rebase = false
	ff = only
[rebase]
	autoStash = true
[diff]
	tool = vimdiff
[fetch]
	prune = true
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
  dark = true
  line-numbers = true
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
